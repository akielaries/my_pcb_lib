Version 14#
setwindow pcb
new
newdrawfillin "ACJSMHOM.dra" "Package Symbol"
prmed
setwindow Form.prmedit
FORM prmedit design
FORM prmedit type Package
FORM prmedit units Millimeter
FORM prmedit size Other
